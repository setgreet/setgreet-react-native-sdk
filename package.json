{
  "name": "@setgreet/react-native-sdk",
  "version": "0.3.0",
  "description": "Official React Native SDK for Setgreet",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "cd example",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "release": "release-it --only-version",
    "publish:patch": "./scripts/publish.sh --patch",
    "publish:minor": "./scripts/publish.sh --minor",
    "publish:major": "./scripts/publish.sh --major",
    "publish:custom": "./scripts/publish.sh",
    "publish:preview": "./scripts/publish.sh --preview"
  },
  "keywords": [
    "setgreet",
    "react-native",
    "ios",
    "android",
    "mobile",
    "app",
    "user",
    "onboarding",
    "sdk",
    "no-code",
    "user engagement",
    "user experience",
    "user retention",
    "mobile app growth",
    "mobile app monetization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/setgreet/setgreet-react-native-sdk.git"
  },
  "author": "Setgreet <hello@setgreet.com> (https://github.com/setgreet)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/setgreet/setgreet-react-native-sdk/issues"
  },
  "homepage": "https://setgreet.com",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/cli": "15.0.0-alpha.2",
    "@react-native/babel-preset": "0.79.2",
    "@react-native/eslint-config": "^0.78.0",
    "@react-native/gradle-plugin": "^0.79.2",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/jest": "^29.5.5",
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/yargs-parser": "^21.0.3",
    "commitlint": "^19.6.1",
    "del-cli": "^5.1.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "turbo": "^1.10.7",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "module",
      "typescript"
    ]
  },
  "codegenConfig": {
    "name": "RNSetgreetSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.setgreet.reactnative"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.52.0"
  }
}
