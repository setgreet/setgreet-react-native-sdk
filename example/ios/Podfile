source 'https://cdn.cocoapods.org/'

# Enable new architecture by default, but can be overridden
ENV['RCT_NEW_ARCH_ENABLED'] = ENV.fetch('RCT_NEW_ARCH_ENABLED', '1')

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'
prepare_react_native_project!

# Specify the Xcode project to use
project 'ReactNativeSetgreetExample.xcodeproj'

# SetgreetSDK is a dynamic XCFramework that dynamically links Lottie,
# so all pods must be built as dynamic frameworks
use_frameworks! :linkage => :dynamic

target 'ReactNativeSetgreetExample' do
  config = use_native_modules!
  
  # Add SetgreetSDK dependency directly
  pod 'SetgreetSDK', :git => 'https://github.com/setgreet/setgreet-ios-sdk.git', :tag => '1.0.0'

  use_react_native!(
    :path => "../node_modules/react-native",
    :hermes_enabled => true,
    :fabric_enabled => true,
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      "../node_modules/react-native",
      :mac_catalyst_enabled => false
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Ensure all pods use at least iOS 15.1 (required by Lottie/SetgreetSDK)
        current = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
        if current && Gem::Version.new(current) < Gem::Version.new('15.1')
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        end
      end

      # SetgreetSDK XCFramework was compiled with library evolution enabled,
      # so Lottie must also be built with it to produce matching dispatch thunks
      if target.name == 'lottie-ios'
        target.build_configurations.each do |config|
          config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
        end
      end
    end
  end
end
